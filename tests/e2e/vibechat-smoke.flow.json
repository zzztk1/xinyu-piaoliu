{
  "schema_version": "1.0",
  "name": "vibechat-drift-cabin-smoke",
  "viewports": [
    { "name": "desktop", "width": 1440, "height": 900 },
    { "name": "mobile-375", "width": 375, "height": 812 }
  ],
  "flows": [
    {
      "name": "drift-cabin-intake-match-chat-echo",
      "path": "/",
      "timeout_ms": 120000,
      "actions": [
        { "type": "waitForSelector", "selector": "[data-testid='auth-stage']", "timeout_ms": 15000 },
        { "type": "click", "selector": "[data-testid='register-button']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='home-stage']", "timeout_ms": 15000 },
        { "type": "click", "selector": "[data-testid='nav-profile']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='profile-stage']", "timeout_ms": 10000 },
        { "type": "fill", "selector": "[data-testid='profile-mbti-input']", "value": "INFP" },
        { "type": "fill", "selector": "[data-testid='profile-zodiac-input']", "value": "双鱼座" },
        { "type": "fill", "selector": "[data-testid='profile-intro-input']", "value": "今晚想轻轻聊几句，不想被催着解决。" },
        { "type": "fill", "selector": "[data-testid='profile-boundary-input']", "value": "不交换联系方式，不聊太深隐私。" },
        { "type": "click", "selector": "[data-testid='save-profile-button']", "timeout_ms": 10000 },
        { "type": "click", "selector": "[data-testid='create-cabin-button']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "text=新的舱灯已经点亮", "timeout_ms": 12000 },
        { "type": "click", "selector": "[data-testid='nav-drift']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='signal-composer']", "timeout_ms": 10000 },
        { "type": "fill", "selector": "[data-testid='mood-input']", "value": "我今晚有点焦虑，也有点空。白天一直在撑着，想找一个不用解释太多的人慢慢说几句。" },
        { "type": "click", "selector": "[data-testid='analyze-button']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='intake-panel']", "timeout_ms": 60000 },
        { "type": "click", "selector": "[data-testid='followup-option-calm-1']", "timeout_ms": 10000 },
        { "type": "click", "selector": "[data-testid='followup-option-energy-0']", "timeout_ms": 10000 },
        { "type": "click", "selector": "[data-testid='followup-option-social-1']", "timeout_ms": 10000 },
        { "type": "click", "selector": "[data-testid='followup-option-stress-2']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='coordinate-panel']", "timeout_ms": 20000 },
        { "type": "click", "selector": "[data-testid='match-button']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='matching-stage']", "timeout_ms": 20000 },
        { "type": "waitForSelector", "selector": "[data-testid='match-preview-panel']", "timeout_ms": 30000 },
        { "type": "click", "selector": "[data-testid='enter-chat-button']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='chat-panel']", "timeout_ms": 30000 },
        { "type": "waitForSelector", "selector": "[data-testid='match-success-panel']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='conversation-status']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='topic-panel']", "timeout_ms": 10000 },
        { "type": "click", "selector": "[aria-label='查看对方公开资料']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='partner-profile-drawer']", "timeout_ms": 10000 },
        { "type": "click", "selector": "text=安全", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='safety-report-menu']", "timeout_ms": 10000 },
        { "type": "click", "selector": "text=让我不舒服的内容", "timeout_ms": 10000 },
        { "type": "fill", "selector": "[data-testid='user-message-input']", "value": "我现在最想先把今天那种紧绷感说出来一点。" },
        { "type": "click", "selector": "[data-testid='user-send-button']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "text=我现在最想先把今天那种紧绷感说出来一点。", "timeout_ms": 15000 },
        { "type": "waitForSelector", "selector": "[data-testid='typing-indicator']", "timeout_ms": 8000 },
        { "type": "waitForTimeout", "ms": 4200 },
        { "type": "click", "selector": "[data-testid='echo-save-button']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='echo-ritual']", "timeout_ms": 10000 },
        { "type": "click", "selector": "[data-testid='collect-echo-button']", "timeout_ms": 10000 },
        { "type": "waitForSelector", "selector": "[data-testid='echo-card']", "timeout_ms": 15000 }
      ],
      "assertions": [
        { "id": "echo-card-visible", "type": "visible", "selector": "[data-testid='echo-card']" },
        { "id": "echo-card-copy", "type": "text", "selector": "[data-testid='echo-card']", "contains": "心情回声卡" },
        { "id": "no-horizontal-scroll", "type": "noHorizontalScroll" }
      ]
    }
  ]
}
